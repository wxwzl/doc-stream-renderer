{
  "name": "doc-stream-renderer-monorepo",
  "private": true,
  "version": "1.0.5",
  "description": "Monorepo for doc-stream-renderer and playground",
  "author": "wxwzl",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm --filter doc-stream-renderer dev",
    "build": "pnpm --filter doc-stream-renderer build",
    "preview": "pnpm --filter doc-stream-renderer preview",
    "lint": "eslint . --ext .js,.mjs,.cjs,.ts,.tsx,.vue",
    "lint:fix": "eslint . --ext .js,.mjs,.cjs,.ts,.tsx,.vue --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "playground": "pnpm run build && pnpm --filter doc-stream-renderer-playground dev",
    "build:playground": "pnpm --filter doc-stream-renderer-playground build",
    "deploy:playground": "pnpm run build:playground && npx gh-pages -d packages/playground/dist",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0"
  },
  "keywords": [
    "doc",
    "streaming",
    "stream",
    "renderer",
    "word"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wxwzl/doc-stream-renderer.git"
  },
  "homepage": "https://github.com/wxwzl/doc-stream-renderer",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "conventional-changelog-cli": "^5.0.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  }
}
