{
  "name": "doc-stream-renderer",
  "version": "1.0.0",
  "description": "A streaming Word document preview component for React and Vue 3",
  "author": "wxwzl",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/core.cjs.js",
  "module": "./dist/core.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core.es.js",
      "require": "./dist/core.cjs.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react.es.js",
      "require": "./dist/react.cjs.js"
    },
    "./vue": {
      "types": "./dist/vue3/index.d.ts",
      "import": "./dist/vue.es.js",
      "require": "./dist/vue.cjs.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "lint": "eslint . --ext .js,.mjs,.cjs,.ts,.tsx,.vue",
    "lint:fix": "eslint . --ext .js,.mjs,.cjs,.ts,.tsx,.vue --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "playground": "cd ./playground && pnpm run dev"
  },
  "dependencies": {
    "docx": "^8.5.0",
    "lodash-es": "^4.17.21",
    "partial-json": "^0.1.7"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0",
    "vue": ">=3.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitejs/plugin-vue": "^5.0.3",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vite-plugin-dts": "^3.7.2",
    "vue-eslint-parser": "^10.4.0"
  }
}
