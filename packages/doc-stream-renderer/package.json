{
  "name": "doc-stream-renderer",
  "version": "1.0.15",
  "description": "A streaming Word document preview component for React and Vue 3",
  "author": "wxwzl",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "main": "./dist/core.cjs.js",
  "module": "./dist/core.es.js",
  "types": "./dist/core.d.ts",
  "exports": {
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core.es.js",
      "require": "./dist/core.cjs.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react.es.js",
      "require": "./dist/react.cjs.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.es.js",
      "require": "./dist/vue.cjs.js"
    }
  },
  "scripts": {
    "prepublish": "pnpm run build",
    "dev": "vite",
    "build": "vite build && cp README.md ../../README.md",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "keywords": [
    "doc",
    "streaming",
    "stream",
    "renderer",
    "word"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wxwzl/doc-stream-renderer.git"
  },
  "homepage": "https://github.com/wxwzl/doc-stream-renderer",
  "dependencies": {
    "partial-json": "^0.1.7"
  },
  "peerDependencies": {
    "docx": "^8.5.0",
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0",
    "vue": ">=3.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitejs/plugin-vue": "^5.0.3",
    "jsdom": "^29.0.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vite-plugin-dts": "^3.7.2",
    "vitest": "2"
  }
}
